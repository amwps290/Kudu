{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting（与根 tsconfig 同强度） */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Path mapping：@ 指向 src 以复用框架无关层（api/types/services/utils/theme/locales） */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@react/*": ["./src-react/*"]
    },

    "types": ["vite/client"]
  },
  "include": ["src-react/**/*.ts", "src-react/**/*.tsx", "src-react/**/*.d.ts"]
}
